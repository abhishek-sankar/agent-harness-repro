# ── Anthropic (required for any live run) ─────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Optional Pi model override. Defaults to the first available model.
# Example: anthropic/claude-sonnet-4-20250514
PI_MODEL=

# ── GitHub (optional for public repos; required for private repos / higher limits) ──
# No local mock fixtures are used. Without a token, GitHub calls are anonymous.
# Create a fine-grained PAT with: Contents (read), Pull Requests (read),
# Actions (read), Metadata (read).
GITHUB_TOKEN=

# ── ElevenLabs (optional — falls back to deterministic silent audio + captions) ────
ELEVENLABS_API_KEY=

# Override the ElevenLabs voice. Default is Rachel (21m00Tcm4TlvDq8ikWAM).
ELEVENLABS_VOICE_ID=

# Override the ElevenLabs model. Default: eleven_multilingual_v2.
ELEVENLABS_MODEL_ID=

# Optional local fallback voice used by the macOS `say` command.
# Disabled by default in the server runtime.
RETURN_BRIEF_SYSTEM_VOICE=Samantha
RETURN_BRIEF_ENABLE_SYSTEM_TTS=0

# If set to 1, configured ElevenLabs API failures fall back to deterministic
# silent audio (or local system speech when RETURN_BRIEF_ENABLE_SYSTEM_TTS=1).
# Default is fail-fast when ELEVENLABS_API_KEY is present.
RETURN_BRIEF_ALLOW_TTS_FALLBACK=0

# ── PR deployment previews (optional) ─────────────────────────────────────
# After opening a draft PR, poll PR comments for a Cloudflare preview URL.
RETURN_BRIEF_DEPLOYMENT_WAIT_MS=360000
RETURN_BRIEF_DEPLOYMENT_POLL_MS=30000

# ── Output location override (optional) ───────────────────────────────────
# By default outputs land in $PWD/outputs/ (the repo you run pi from).
# Override to write them somewhere specific regardless of cwd.
# RETURN_BRIEF_ROOT=/path/to/my-portfolio-repo

# ── Pi-on-Railway service runtime ──────────────────────────────────────────
AGENT_API_TOKEN=
DATABASE_URL=
REDIS_URL=
RETURN_BRIEF_PUBLIC_BASE_URL=http://127.0.0.1:3000
RETURN_BRIEF_AGENT_DIR=.runtime/pi

# Pre-registered trusted repos for the API/worker.
# Example:
# RETURN_BRIEF_REPOS_JSON=[{"id":"portfolio","name":"Portfolio","repo":"owner/repo","cloneUrl":"https://github.com/owner/repo.git","defaultBranch":"main","installCommand":"npm ci","startCommand":"npm run dev","port":3000,"healthcheckPath":"/","testCommands":["npm run build"],"envAllowlist":["NEXT_PUBLIC_API_URL"]}]
RETURN_BRIEF_REPOS_JSON=[]

# Local development artifact bucket fallback.
RETURN_BRIEF_LOCAL_BUCKET_DIR=outputs/server-artifacts

# Railway Bucket / S3-compatible settings (optional; takes precedence when set).
# AWS_BUCKET_NAME=
# AWS_REGION=us-east-1
# AWS_ENDPOINT_URL_S3=
