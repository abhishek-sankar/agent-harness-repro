{
  "name": "return-brief",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Async DevEx agent as a pi extension. Idle audits + narrated video return brief.",
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  },
  "scripts": {
    "api": "tsx src/server/bin/api.ts",
    "worker": "tsx src/server/bin/worker.ts",
    "test": "tsx --test src/*.test.ts src/**/*.test.ts",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.917.0",
    "@aws-sdk/s3-request-presigner": "^3.917.0",
    "@mariozechner/pi-coding-agent": "^0.70.2",
    "bullmq": "^5.58.0",
    "fastify": "^5.6.1",
    "ioredis": "^5.8.2",
    "playwright": "^1.49.0",
    "pg": "^8.16.3",
    "typebox": "^1.1.33",
    "undici": "^7.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.6",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
